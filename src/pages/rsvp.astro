---
import Layout from "@/layouts/Layout.astro";
import RsvpForm from "@/components/react/RsvpForm";
import LanguageSwitcher from "@/components/LanguageSwitcher.astro";
import DividerWhite from "@/components/DividerWhite.astro";
import { Image } from "astro:assets";
import heroImage1 from "@/assets/images/rsvp.jpg";
import { t } from "@/i18n/translations";
import type { Lang } from "@/i18n/translations";

const lang: Lang = "ja";

const rsvpLabels = {
  rsvpTitle: t(lang, "rsvpTitle"),
  rsvpDeadline: t(lang, "rsvpDeadline"),
  nameLabel: t(lang, "nameLabel"),
  namePlaceholder: t(lang, "namePlaceholder"),
  nameFuriganaLabel: t(lang, "nameFuriganaLabel"),
  nameFuriganaPlaceholder: t(lang, "nameFuriganaPlaceholder"),
  coAttendeesLabel: t(lang, "coAttendeesLabel"),
  coAttendeesNote: t(lang, "coAttendeesNote"),
  coAttendeePlaceholder: t(lang, "coAttendeePlaceholder"),
  coAttendeeFuriganaPlaceholder: t(lang, "coAttendeeFuriganaPlaceholder"),
  guestSideLabel: t(lang, "guestSideLabel"),
  groomGuest: t(lang, "groomGuest"),
  brideGuest: t(lang, "brideGuest"),
  phoneLabel: t(lang, "phoneLabel"),
  phonePlaceholder: t(lang, "phonePlaceholder"),
  emailLabel: t(lang, "emailLabel"),
  emailPlaceholder: t(lang, "emailPlaceholder"),
  postalCodeLabel: t(lang, "postalCodeLabel"),
  postalCodePlaceholder: t(lang, "postalCodePlaceholder"),
  addressLabel: t(lang, "addressLabel"),
  addressPlaceholder: t(lang, "addressPlaceholder"),
  attendanceLabel: t(lang, "attendanceLabel"),
  attending: t(lang, "attending"),
  notAttending: t(lang, "notAttending"),
  guestCountLabel: t(lang, "guestCountLabel"),
  dietaryLabel: t(lang, "dietaryLabel"),
  dietaryNote: t(lang, "dietaryNote"),
  dietaryPlaceholder: t(lang, "dietaryPlaceholder"),
  taxiLabel: t(lang, "taxiLabel"),
  taxiNote: t(lang, "taxiNote"),
  taxiNotNeeded: t(lang, "taxiNotNeeded"),
  taxiOneWay: t(lang, "taxiOneWay"),
  taxiRoundTrip: t(lang, "taxiRoundTrip"),
  messageLabel: t(lang, "messageLabel"),
  messagePlaceholder: t(lang, "messagePlaceholder"),
  submit: t(lang, "submit"),
  submitting: t(lang, "submitting"),
  thankYouTitle: t(lang, "thankYouTitle"),
  thankYouMessage: t(lang, "thankYouMessage"),
  thankYouNotAttending: t(lang, "thankYouNotAttending"),
  errorMessage: t(lang, "errorMessage"),
  nameRequired: t(lang, "nameRequired"),
  attendanceRequired: t(lang, "attendanceRequired"),
  phoneRequired: t(lang, "phoneRequired"),
  guestSideRequired: t(lang, "guestSideRequired"),
  requiredLabel: t(lang, "requiredLabel"),
};
---

<Layout lang={lang} title={`${t(lang, "rsvpTitle")} — Natsuki & Anthony`}>
  <LanguageSwitcher lang={lang} />
  <div class="min-h-screen pb-12">
    <div class="pt-12 relative z-20 text-center px-4 w-full text-white bg-black">
      <div class="absolute inset-0 h-full w-full overflow-hidden">
        <Image src={heroImage1} alt="" class="absolute inset-0 h-full w-full object-cover opacity-100 blur-xl scale-105 transition-opacity duration-1000" quality="low" width={40} />
        <Image src={heroImage1} alt="" class="absolute inset-0 h-full w-full object-cover opacity-0 transition-opacity duration-1000" quality="high" width={1920} sizes="100vw" onload="this.style.opacity='1'; this.previousElementSibling.style.opacity='0'" />
        <div class="absolute inset-0 bg-gradient-to-t from-black/40 via-black/20 to-transparent"></div>
      </div>
    <div class="hero-animate z-21">
    <div class="mt-48 mb-8 flex justify-center">
      <p class="writing-text text-5xl md:text-7xl text-white" style="font-family: var(--font-calligraphy);">
        Wedding Invitation
      </p>
    </div>
    <DividerWhite />
    <div class="mt-4 pb-12">
    <h1
      class="text-2xl font-light mb-3 text-white"
      style="font-family: var(--font-serif-latin);"
    >
      Anthony <span class="mx-2 text-xl font-extralight lowercase text-white">&</span> Natsuki
    </h1>
    <p class="text-xs tracking-[0.3em] text-white uppercase" style="font-family: var(--font-serif-latin);">
      {t(lang, "weddingDateShort")}
    </p>
    </div>
    </div>
  </div>
    
    <RsvpForm client:visible lang={lang} labels={rsvpLabels} />
    <div class="mx-auto flex justify-center">
      <a href="/" class="flex flex-row items-center text-charcoal/70 hover:text-gold transition-colors">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="mr-2">
          <path d="M19 12H5M12 19l-7-7 7-7"/>
        </svg>
        <span class="text-sm uppercase tracking-widest">Back</span>
      </a>
    </div>
  </div>
</Layout>
