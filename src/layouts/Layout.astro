---
import { ClientRouter } from "astro:transitions";
import "@/styles/global.css";
import type { Lang } from "@/i18n/translations";
import { t } from "@/i18n/translations";

interface Props {
  lang: Lang;
  title?: string;
}

const { lang, title = "Wedding Invitation" } = Astro.props;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="robots" content="noindex, nofollow" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <meta name="description" content="Wedding Invitation" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Pinyon+Script&family=Playfair+Display:ital,wght@0,400;0,500;1,400&family=Noto+Serif+JP:wght@300;400;500;600&display=swap"
      rel="stylesheet"
    />
    <ClientRouter />
    <title>{title}</title>
  </head>
  <body class="min-h-[100svh] bg-[#fff2ef]">
    <div class="w-full max-w-[800px] mx-auto bg-[#FFFFFF] min-h-[100svh] shadow-lg relative">
      <slot />
    </div>
  </body>
</html>
