---
import type { Lang } from "@/i18n/translations";
import { t } from "@/i18n/translations";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
---

<section>
  <div class="max-w-3xl mx-auto text-center">
    <p class="text-sm text-charcoal mb-4">{t(lang, "footerText")}</p>
    <p
      class="text-2xl font-light tracking-wide text-charcoal mb-2"
      style="font-family: var(--font-serif-latin);"
    >
      Anthony <span class="text-gold">&</span> Natsuki
    </p>
    <p class="text-xs tracking-widest text-charcoal" style="font-family: var(--font-serif-latin);">
      {t(lang, "weddingDateShort")}
    </p>
  </div>
</section>
