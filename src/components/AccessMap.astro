---
import type { Lang } from "@/i18n/translations";
import { t } from "@/i18n/translations";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
---

<section id="access">
  <div class="max-w-3xl mx-auto">
    <h2
      class="scroll-reveal text-xl md:text-2xl tracking-[0.2em] font-bold uppercase text-gold mb-8 text-center"
      style="font-family: var(--font-serif-latin);"
    >
      {t(lang, "accessTitle")}
    </h2>
    <div class="scroll-reveal mb-8 rounded-sm overflow-hidden border border-gold-light/30">
      <iframe
        src="https://maps.google.com/maps?q=%E3%83%AC%E3%82%A2%E3%83%BC%E3%83%AB%E3%83%89%E3%82%BB%E3%82%BE%E3%83%B3%E3%83%BB%E3%82%BB%E3%83%BC%E3%82%B8&t=&z=15&ie=UTF8&iwloc=&output=embed"
        width="100%"
        height="350"
        style="border:0;"
        allowfullscreen=""
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        title="Venue Map"></iframe>
    </div>
    <div class="scroll-reveal-delay-1 space-y-3 text-sm text-charcoal text-center">
      <p class="whitespace-pre-line">{t(lang, "accessStation")}</p>
      <p class="whitespace-pre-line">{t(lang, "accessBus")}</p>
      <p class="whitespace-pre-line">{t(lang, "accessParking")}</p>
    </div>
  </div>
</section>
