---
import type { Lang } from "@/i18n/translations";
import { t } from "@/i18n/translations";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const lines = t(lang, "greetingBody").split("\n");
---

<section class="flex justify-center" id="greeting">
  <div class="scroll-reveal text-center">
    <h2
      class="text-xl md:text-2xl tracking-[0.2em] font-bold uppercase text-gold mb-8"
      style="font-family: var(--font-serif-latin);"
    >
      {t(lang, "greetingTitle")}
    </h2>
    <div class="space-y-0 leading-[2.2] text-base md:text-lg text-[#231815]">
      {lines.map((line) => (
        line.trim() === "" ? "" : <p>{line}</p>
      ))}
      <div class="text-right mt-6 mb-8 text-sm md:text-base">
        <p class="mb-4">{t(lang, "greetingDate")}</p>
        {lang === "ja" ? (
          <div class="space-y-1">
            <p>シャプ　アントニー</p>
            <p>シャプ　夏生　(旧姓 宮木)</p>
          </div>
        ) : (
          <span style="font-family: var(--font-serif-latin);">Anthony <span class="text-gold">&</span> Natsuki</span>
        )}
      </div>
    </div>
  </div>
</section>
