---
import { Image } from "astro:assets";
import heroImage1 from "@/assets/images/hero-1.jpg";
import heroImage2 from "@/assets/images/hero-2.jpg";
import heroImage3 from "@/assets/images/hero-3.jpg";
import type { Lang } from "@/i18n/translations";
import DividerWhite from "@/components/DividerWhite.astro";
import { t } from "@/i18n/translations";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
---

<section id="hero-section" class="relative flex h-screen items-end justify-center pb-36 bg-black">

<!-- Opening Grandient Overlay with Motifs -->
    <div class="opening-gradient-overlay absolute inset-0 w-screen left-1/2 -translate-x-1/2 h-full z-11 overflow-hidden">
      <div class="animation__motif animation__motif--1"></div>
      <div class="animation__motif animation__motif--2"></div>
    </div>
  
  <!-- Blurred background extending beyond the 800px max-width container -->
  <div class="absolute inset-0 w-screen left-1/2 -translate-x-1/2 h-full z-0 pointer-events-none overflow-hidden touch-none">
    <Image src={heroImage1} alt="" class="hero-bg hero-bg-1 absolute inset-0 h-full w-full object-cover blur-[10px] opacity-50 scale-125" widths={[640]} sizes="100vw" />
    <Image src={heroImage2} alt="" class="hero-bg hero-bg-2 absolute inset-0 h-full w-full object-cover blur-[10px] opacity-50 scale-125" widths={[640]} sizes="100vw" />
    <Image src={heroImage3} alt="" class="hero-bg hero-bg-3 absolute inset-0 h-full w-full object-cover blur-[10px] opacity-50 scale-125" widths={[640]} sizes="100vw" />
    <!-- Gradient overlay for text reading -->
    <div class="absolute inset-0 bg-gradient-to-t from-black/40 via-black/20 to-transparent z-10"></div>
  </div>

  <!-- Clear hero images contained within the main 800px column -->
  <div class="absolute inset-0 z-10 overflow-hidden">
    <Image src={heroImage1} alt="Hero 1" class="hero-bg hero-bg-1 absolute inset-0 h-full w-full object-cover" quality="high" width={1920} />
    <Image src={heroImage2} alt="Hero 2" class="hero-bg hero-bg-2 absolute inset-0 h-full w-full object-cover" quality="high" width={1920} />
    <Image src={heroImage3} alt="Hero 3" class="hero-bg hero-bg-3 absolute inset-0 h-full w-full object-cover" quality="high" width={1920} />

    <!-- Gradient overlay for text reading -->
    <div class="absolute inset-0 bg-gradient-to-t from-black/40 via-black/20 to-transparent z-10"></div>
  </div>
  
  <!-- Decorative Arch Frame -->
  <div class="absolute inset-x-5 top-12 bottom-0 md:max-w-2xl md:mx-auto pointer-events-none z-20">
    <!-- Continuous Arch Lines -->
    <div class="w-full h-full relative">
      <div class="absolute inset-0 border border-b-0 border-white rounded-t-full"></div>
      <div class="absolute inset-1.5 md:inset-2 border border-b-0 border-white/50 rounded-t-full"></div>
    </div>
    
    <!-- Minimalist Elegant Line-Art Ribbon Bow (Wedding Classic) -->
    <div class="absolute top-[-1.8rem] md:top-[-2rem] left-1/2 -translate-x-1/2 text-white">
      <svg viewBox="0 0 100 60" class="w-26 h-20 md:w-30 md:h-22" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <!-- Left Loop -->
        <path d="M 50 20 C 30 0, 10 15, 25 28 C 35 35, 45 25, 50 20 Z" />
        <!-- Right Loop -->
        <path d="M 50 20 C 70 0, 90 15, 75 28 C 65 35, 55 25, 50 20 Z" />
        <!-- Left Tail -->
        <path d="M 48 22 C 35 35, 25 50, 25 50" />
        <path d="M 44.5 24 C 38 35, 32 45, 32 45" stroke-width="1" opacity="0.5" />
        <!-- Right Tail -->
        <path d="M 52 22 C 65 35, 75 50, 75 50" />
        <path d="M 55.5 24 C 62 35, 68 45, 68 45" stroke-width="1" opacity="0.5" />
        <!-- Central Knot -->
        <ellipse cx="50" cy="20" rx="3" ry="4" fill="currentColor" stroke="none" />
      </svg>
    </div>
  </div>

  <div class="hero-animate relative z-20 text-center px-4 w-full text-white flex flex-col gap-6">
    <div class="flex justify-center mb-2 text-white">
      <svg id="animation__title" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 773.067 425.429" class="w-[280px] md:w-[380px] fill-current text-white active painted">
