    const hero = document.getElementById('hero-section');
    if (hero) {
      hero.style.height = `${window.innerHeight}px`;
    }
  }

  // Set the precise height right away
  setHeroHeight();
  
  // Re-run if using view transitions
  document.addEventListener('astro:page-load', setHeroHeight);

  // Recalculate *only* when device rotates (width changes), ignore vertical scrolling triggers
  let currentWidth = window.innerWidth;
  window.addEventListener('resize', () => {
    if (window.innerWidth !== currentWidth) {
      currentWidth = window.innerWidth;
      setHeroHeight();
    }
  });
</script>
