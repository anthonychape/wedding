---
import { Image } from "astro:assets";
import groomImage from "@/assets/images/groom.jpg";
import brideImage from "@/assets/images/bride.jpg";
import type { Lang } from "@/i18n/translations";
import { t } from "@/i18n/translations";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
---

<section id="profile" class="w-full px-6 md:px-8 mx-auto max-w-4xl">
  <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-10">
    <!-- Groom -->
    <div class="relative w-full aspect-[9/16] rounded-sm overflow-hidden scroll-reveal group">
      <!-- Groom Ribbon -->
      <div class="absolute bottom-8 -right-12 w-[200px] -rotate-45 bg-gradient-to-r from-[#efd59e] to-[#e29886] text-white py-1.5 shadow-xl z-20 overflow-hidden">
        <span class="text-3xl block text-center drop-shadow-md" style="font-family: var(--font-calligraphy);">The Groom</span>
        <div class="absolute top-0 bottom-0 w-[50%] animate-shine bg-gradient-to-r from-transparent via-white/50 to-transparent skew-x-[-20deg]"></div>
      </div>
      <Image
        src={groomImage}
        alt={t(lang, "groomName")}
        class="absolute inset-0 w-full h-full object-cover"
        quality="high"
        width={1080}
      />
      <div class="absolute inset-x-0 top-0 h-[40%] bg-gradient-to-b from-black/30 to-transparent transition-colors group-hover:from-black/40"></div>
      <div class="absolute inset-0 flex flex-col items-center justify-start pt-10 md:pt-12 text-white px-4">
        <h3
          class="text-4xl md:text-5xl font-light mb-2"
          style="font-family: var(--font-serif-latin);"
        >
          {t(lang, "groomName")}
        </h3>
        <p class="text-sm md:text-base text-white/90 tracking-widest uppercase">{t(lang, "groomNameJp")}</p>
      </div>
    </div>

    <!-- Bride -->
    <div class="relative w-full aspect-[9/16] rounded-sm overflow-hidden scroll-reveal group">
      <!-- Bride Ribbon -->
      <div class="absolute bottom-8 -right-12 w-[200px] -rotate-45 bg-gradient-to-r from-[#efd59e] to-[#e29886] text-white py-1.5 shadow-xl z-20 overflow-hidden">
        <span class="text-3xl block text-center drop-shadow-md" style="font-family: var(--font-calligraphy);">The Bride</span>
        <div class="absolute top-0 bottom-0 w-[50%] animate-shine bg-gradient-to-r from-transparent via-white/50 to-transparent skew-x-[-20deg]"></div>
      </div>
      <Image
        src={brideImage}
        alt={t(lang, "brideName")}
        class="absolute inset-0 w-full h-full object-cover"
        quality="high"
        width={1080}
      />
      <div class="absolute inset-x-0 top-0 h-[40%] bg-gradient-to-b from-black/30 to-transparent transition-colors group-hover:from-black/40"></div>
      <div class="absolute inset-0 flex flex-col items-center justify-start pt-10 md:pt-12 text-white px-4">
        <h3
          class="text-4xl md:text-5xl font-light mb-2"
          style="font-family: var(--font-serif-latin);"
        >
          {t(lang, "brideName")}
        </h3>
        <p class="text-sm md:text-base text-white/90 tracking-widest uppercase">{t(lang, "brideNameJp")}</p>
      </div>
    </div>
  </div>
</section>

<style>
  .animate-shine {
    animation: shine 4s ease-in-out infinite;
    left: -100%;
  }

  @keyframes shine {
    0% { left: -100%; }
    20% { left: 200%; }
    100% { left: 200%; }
  }
</style>
